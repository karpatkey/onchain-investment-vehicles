# RPC endpoints. Aliases match script/ccip-networks.json chain names. Replace public defaults with
# your own (Alchemy/Infura/etc.) — public RPCs rate-limit and may be unreliable for broadcasts.
MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/
GNOSIS_URL=https://gnosis-mainnet.g.alchemy.com/v2/
ARBITRUM_URL=https://arb-mainnet.g.alchemy.com/v2/
BASE_URL=https://base-mainnet.g.alchemy.com/v2/
OP_URL=https://opt-mainnet.g.alchemy.com/v2/
SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/

# Additional CCIP target chains (public-RPC defaults; verified reachable June 2026):
BNB_URL=https://bsc-rpc.publicnode.com
POLYGON_URL=https://polygon-bor-rpc.publicnode.com
AVALANCHE_URL=https://avalanche-c-chain-rpc.publicnode.com
CELO_URL=https://forno.celo.org
LINEA_URL=https://linea-rpc.publicnode.com
SCROLL_URL=https://scroll-rpc.publicnode.com
SONIC_URL=https://sonic-rpc.publicnode.com
UNICHAIN_URL=https://mainnet.unichain.org
WORLDCHAIN_URL=https://worldchain-mainnet.gateway.tenderly.co
HYPEREVM_URL=https://rpc.hyperliquid.xyz/evm
MANTLE_URL=https://rpc.mantle.xyz
PLASMA_URL=https://rpc.plasma.to
INK_URL=https://rpc-gel.inkonchain.com
BOB_URL=https://rpc.gobob.xyz
BERACHAIN_URL=https://berachain-rpc.publicnode.com
KATANA_URL=https://rpc.katana.network

# Optional: hand factory + orchestrator ownership to this address after deploy (defaults to the
# deployer EOA so it keeps control — set to a governance multisig for production).
DEPLOY_FINAL_OWNER=

# Etherscan v2 multichain API key — one key covers mainnet, optimism, base, arbitrum, gnosis, sepolia.
# Get from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Foundry encrypted keystore account names (see `cast wallet import`)
MAINNET_DEPLOYER_NAME=
SEPOLIA_DEPLOYER_NAME=

# Raw private key — used by legacy scripts (DeployKpkShares, DeployKpkSharesSepolia)
PRIVATE_KEY=